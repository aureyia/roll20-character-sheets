include ./container
include ../../oracles/mixins/oracle-table
include ../../oracles/mixins/oracle-roll-btn

mixin movePreviewFactory(move, options)
  +container(move, options)
    -
      const moveId = move.id
      const hasOracles = move.Oracles && move.Oracles.length
      // dataforged bakes the oracle result table into the move's own rules-text
      // as a Markdown table (rendered to an HTML <table>). Strip it so the styled,
      // data-driven oracle table rendered below isn't a duplicate — the oracle
      // table is the canonical, translatable version.
      let rulesText = translation[`move-text-${moveId}`] || ''
      if (hasOracles) rulesText = rulesText.replace(/<table[\s\S]*?<\/table>/gi, '')
    .rules-text !{rulesText}
    if hasOracles
      .move-oracle-container
        -
          // Resolve each oracle $id the move references to a renderable oracle.
          // A move ref points at either a top-level oracle (e.g. Begin a Session,
          // or Misc/Story Clue for Gather Information) or the leaf sub-oracles of
          // an oracle-with-sub-oracles (Ask the Oracle's five likelihoods) — in
          // the latter case render the PARENT once as a combined "choose" button.
          // Dedupe by $id so repeated sub-oracle refs collapse to a single button.
          function renderableFor(id) {
            for (const group of oracles) {
              const level1 = [].concat(
                group.Oracles || [],
                ...(group.Categories || []).map((c) => c.Oracles || [])
              );
              for (const oracle of level1) {
                if (oracle['$id'] === id) return oracle;
                if (oracle.Oracles && oracle.Oracles.some((s) => s['$id'] === id)) return oracle;
              }
            }
            return null;
          }
          const seenOracleIds = new Set();
          const moveOracles = [];
          move.Oracles.forEach((oracleId) => {
            const resolved = renderableFor(oracleId);
            if (resolved && !seenOracleIds.has(resolved['$id'])) {
              seenOracleIds.add(resolved['$id']);
              moveOracles.push(resolved);
            }
          });
        each moveOracle in moveOracles
          - const btnText = `Roll: ${moveOracle.Name}`
          if moveOracle.Table
            +oracleSingleButton(moveOracle, btnText)
            +oracleTable(moveOracle, false, true)
          else if moveOracle.Oracles
            +oracleMultiBtn(moveOracle, btnText)
            +oracleMultiSubTable(moveOracle, false, true)

mixin movePreview(move, options)
  if options.no_title
    div
  else
    div.move-title.move-preview=move.Name
      if move['Progress Move']
        span.move-progress-label='Progress Move'
  if move.Trigger.Options
    -
      let rollType = ''
      const moveTriggerOptions = move.Trigger.Options.filter(option => { return option['Roll type'] === 'Action roll' || option['Roll type'] === 'Progress roll'})
      const areOnlyActionRollOptions = moveTriggerOptions.every((option) => option['Roll type'] === 'Action roll')
      const areOnlyProgressRollOptions = moveTriggerOptions.every((option) => option['Roll type'] === 'Progress roll')
      if(areOnlyActionRollOptions === true) {
        rollType = 'Action roll'
      } else if (areOnlyProgressRollOptions === true) {
        rollType = 'Progress roll'
      } else {
        rollType = 'Mixed roll'
      }
    if rollType === 'Progress roll'
      +rollLabel
        +progressRoll(move, 'hide-element')
    else if rollType === 'Action roll'
      +rollLabel
        +movesRoll(move, 'hidden-button')

  .move-description
    block
  .oracle-footer.move-page-footer=move.Page

mixin container(move, options = false)
  - const moveId = `move-${move.id}`
  if options.visibility
    div.move-visible.surface
      +movePreview(move, options)
        block
  else
    input(type='radio' name='attr_move_preview' class=`${moveId} hide-element` value=move.id)
    div(class=`${moveId} surface showhide`)
      +movePreview(move, options)
        block